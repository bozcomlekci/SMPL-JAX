+CliOptions parse_args(int argc, char *argv[]) {
+    if (argc < 2) {
+        throw std::runtime_error("Missing model path argument");
+    }
+
+    CliOptions opts;
+    opts.model_path = argv[1];
+
+    for (int i = 2; i < argc; ++i) {
+        const std::string arg = argv[i];
+        auto next_value = [&](const std::string &flag) -> std::string {
+            if (i + 1 >= argc) {
+                throw std::runtime_error("Missing value for flag: " + flag);
+            }
+            return argv[++i];
+        };
+
+        if (arg == "--sequence") {
+            opts.sequence_path = next_value(arg);
+        } else if (arg == "--max-frames") {
+            opts.max_frames = std::stoi(next_value(arg));
+        } else if (arg == "--warmup") {
+            opts.warmup = std::stoi(next_value(arg));
+        } else if (arg == "--repeats") {
+            opts.repeats = std::stoi(next_value(arg));
+        } else if (arg == "--iterations") {
+            opts.iterations = std::stoi(next_value(arg));
+        } else if (arg == "--device") {
+            opts.device = next_value(arg);
+        } else if (arg == "--dtype") {
+            opts.dtype = next_value(arg);
+        } else if (arg == "--help" || arg == "-h") {
+            print_usage(argv[0]);
+            std::exit(0);
+        } else {
+            throw std::runtime_error("Unknown argument: " + arg);
+        }
+    }
+
+    if (opts.warmup < 0 || opts.repeats <= 0 || opts.iterations <= 0 ||
+        opts.max_frames < 0) {
+        throw std::runtime_error(
+            "Invalid numeric argument: warmup>=0, repeats>0, iterations>0, "
+            "max_frames>=0 required");
+    }
+
+    if (opts.device != "auto" && opts.device != "cpu" && opts.device != "cuda") {
+        throw std::runtime_error("--device must be one of: auto, cpu, cuda");
+    }
+    if (opts.dtype != "float32" && opts.dtype != "float64") {
+        throw std::runtime_error("--dtype must be one of: float32, float64");
+    }
+
+    return opts;
+}
