+template <typename T>
+torch::Tensor npy2d_to_tensor(const cnpy::NpyArray &arr, int expected_cols,
+                              const torch::Device &device) {
+    if (arr.shape.size() != 2) {
+        throw std::runtime_error("Expected 2D npy array");
+    }
+    const int64_t rows = static_cast<int64_t>(arr.shape[0]);
+    const int64_t cols = static_cast<int64_t>(arr.shape[1]);
+    if (expected_cols > 0 && cols != expected_cols) {
+        throw std::runtime_error("Unexpected column count in sequence tensor");
+    }
+
+    const T *src = arr.data<T>();
+    std::vector<double> values(static_cast<size_t>(rows * cols));
+    for (int64_t r = 0; r < rows; ++r) {
+        for (int64_t c = 0; c < cols; ++c) {
+            const int64_t src_idx =
+                arr.fortran_order ? (c * rows + r) : (r * cols + c);
+            values[static_cast<size_t>(r * cols + c)] =
+                static_cast<double>(src[src_idx]);
+        }
+    }
+
+    auto tensor = torch::from_blob(values.data(), {rows, cols}, torch::kFloat64)
+                      .clone()
+                      .to(device);
+    return tensor;
+}
+
+torch::Tensor npy2d_to_tensor_double(const cnpy::NpyArray &arr,
+                                     int expected_cols,
+                                     const torch::Device &device) {
+    if (arr.word_size == sizeof(double)) {
+        return npy2d_to_tensor<double>(arr, expected_cols, device);
+    }
+    if (arr.word_size == sizeof(float)) {
+        return npy2d_to_tensor<float>(arr, expected_cols, device);
+    }
+    throw std::runtime_error("Unsupported dtype for 2D sequence tensor");
+}
+
+template <typename T>
+torch::Tensor npy1d_to_tensor(const cnpy::NpyArray &arr,
+                              const torch::Device &device) {
+    int64_t n = 0;
+    if (arr.shape.size() == 1) {
+        n = static_cast<int64_t>(arr.shape[0]);
+    } else if (arr.shape.size() == 2 && arr.shape[0] == 1) {
+        n = static_cast<int64_t>(arr.shape[1]);
+    } else if (arr.shape.size() == 2 && arr.shape[1] == 1) {
+        n = static_cast<int64_t>(arr.shape[0]);
+    } else {
+        throw std::runtime_error("Expected 1D betas array");
+    }
+
+    const T *src = arr.data<T>();
+    std::vector<double> values(static_cast<size_t>(n));
+    for (int64_t i = 0; i < n; ++i) {
+        values[static_cast<size_t>(i)] = static_cast<double>(src[i]);
+    }
+
+    return torch::from_blob(values.data(), {n}, torch::kFloat64).clone().to(device);
+}
+
+torch::Tensor npy1d_to_tensor_double(const cnpy::NpyArray &arr,
+                                     const torch::Device &device) {
+    if (arr.word_size == sizeof(double)) {
+        return npy1d_to_tensor<double>(arr, device);
+    }
+    if (arr.word_size == sizeof(float)) {
+        return npy1d_to_tensor<float>(arr, device);
+    }
+    throw std::runtime_error("Unsupported dtype for 1D sequence tensor");
+}
+
+double percentile(std::vector<double> values, double q) {
+    if (values.empty()) {
+        throw std::runtime_error("Cannot compute percentile of empty values");
+    }
+    std::sort(values.begin(), values.end());
+    const double pos = (q / 100.0) * static_cast<double>(values.size() - 1);
+    const auto lo = static_cast<size_t>(std::floor(pos));
+    const auto hi = static_cast<size_t>(std::ceil(pos));
+    const double w = pos - static_cast<double>(lo);
+    return values[lo] * (1.0 - w) + values[hi] * w;
+}
+
+SequenceInputs load_sequence_inputs(const std::string &sequence_path,
+                                    smplx::SMPL &model,
+                                    const torch::Device &device,
+                                    int max_frames,
+                                    torch::ScalarType dtype) {
+    if (!std::filesystem::exists(sequence_path)) {
+        throw std::runtime_error("Sequence path does not exist: " + sequence_path);
+    }
+
+    const cnpy::npz_t seq = cnpy::npz_load(sequence_path);
+    const auto require = [&](const std::string &name) -> const cnpy::NpyArray & {
+        auto it = seq.find(name);
+        if (it != seq.end()) {
+            return it->second;
+        }
+        it = seq.find(name + ".npy");
+        if (it != seq.end()) {
+            return it->second;
+        }
+        std::string available;
+        for (const auto &kv : seq) {
+            if (!available.empty()) {
+                available += ", ";
+            }
+            available += kv.first;
+        }
+        throw std::runtime_error("Missing key in sequence npz: " + name +
+                                 " (available: [" + available + "])");
+    };
+
+    auto transl = npy2d_to_tensor_double(require("trans"), 3, device);
+    auto global_orient = npy2d_to_tensor_double(require("root_orient"), 3, device);
+    auto pose_body = npy2d_to_tensor_double(require("pose_body"), 63, device);
+    auto betas_raw = npy1d_to_tensor_double(require("betas"), device);
+
+    transl = transl.to(dtype);
+    global_orient = global_orient.to(dtype);
+    pose_body = pose_body.to(dtype);
+    betas_raw = betas_raw.to(dtype);
+
+    int64_t n_frames = transl.size(0);
+    if (global_orient.size(0) != n_frames || pose_body.size(0) != n_frames) {
+        throw std::runtime_error(
+            "Sequence arrays have inconsistent first dimension lengths");
+    }
+
+    if (max_frames > 0 && n_frames > max_frames) {
+        n_frames = max_frames;
+        transl = transl.narrow(0, 0, n_frames).clone();
+        global_orient = global_orient.narrow(0, 0, n_frames).clone();
+        pose_body = pose_body.narrow(0, 0, n_frames).clone();
+    }
+
+    auto zeros6 = torch::zeros({n_frames, 6}, torch::dtype(dtype).device(device));
+    auto body_pose69 = torch::cat({pose_body, zeros6}, 1);
+
+    auto betas_one =
+        torch::zeros({model.num_betas()}, torch::dtype(dtype).device(device));
+    const int64_t copy_n = std::min<int64_t>(betas_one.size(0), betas_raw.numel());
+    if (copy_n > 0) {
+        betas_one.narrow(0, 0, copy_n).copy_(betas_raw.narrow(0, 0, copy_n));
+    }
+    auto betas_batch = betas_one.unsqueeze(0).repeat({n_frames, 1});
+
+    return {betas_batch, global_orient, body_pose69, transl, n_frames};
+}
