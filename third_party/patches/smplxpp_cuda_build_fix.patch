+template <class ModelConfig>
+class FusedBatchForward {
+   public:
+    using ModelClass = Model<ModelConfig>;
+    using BodyClass = Body<ModelConfig>;
+
+    FusedBatchForward(py::object model_owner, size_t batch_capacity)
+        : model_owner_(std::move(model_owner)),
+          model_(&model_owner_.cast<ModelClass&>()),
+          n_pose_params_(ModelConfig::n_explicit_joints() * 3),
+          n_shape_blends_(ModelConfig::n_shape_blends()),
+          n_verts_(model_->n_verts()) {
+        if (batch_capacity == 0) {
+            throw std::invalid_argument("batch_capacity must be > 0");
+        }
+        bodies_.reserve(batch_capacity);
+        for (size_t i = 0; i < batch_capacity; ++i) {
+            bodies_.emplace_back(new BodyClass(*model_));
+        }
+
+#ifdef SMPLX_CUDA_ENABLED
+        cuda_streams_.assign(batch_capacity, nullptr);
+        for (size_t i = 0; i < batch_capacity; ++i) {
+            cudaStream_t stream = nullptr;
+            if (cudaStreamCreateWithFlags(&stream, cudaStreamNonBlocking) ==
+                cudaSuccess) {
+                cuda_streams_[i] = reinterpret_cast<void*>(stream);
+            }
+        }
+#endif
+    }
+
+    FusedBatchForward(const FusedBatchForward&) = delete;
+    FusedBatchForward& operator=(const FusedBatchForward&) = delete;
+    FusedBatchForward(FusedBatchForward&&) noexcept = default;
+    FusedBatchForward& operator=(FusedBatchForward&&) noexcept = default;
+
+    ~FusedBatchForward() {
+#ifdef SMPLX_CUDA_ENABLED
+        for (void* stream_handle : cuda_streams_) {
+            if (stream_handle != nullptr) {
+                cudaStreamDestroy(
+                    reinterpret_cast<cudaStream_t>(stream_handle));
+            }
+        }
+#endif
+    }
+
+    size_t batch_capacity() const { return bodies_.size(); }
+
+    void set_betas(py::array_t<float, py::array::c_style | py::array::forcecast>
+                       betas) {
+        const auto info = betas.request();
+        if (info.ndim != 1 && info.ndim != 2) {
+            throw std::invalid_argument(
+                "betas must have shape (n_shape_blends,) or "
+                "(batch_capacity, n_shape_blends)");
+        }
+
+        const auto* beta_ptr = static_cast<const float*>(info.ptr);
+        if (info.ndim == 1) {
+            const size_t src_n = static_cast<size_t>(info.shape[0]);
+            const size_t copy_n = std::min(src_n, n_shape_blends_);
+            for (auto& body_ptr : bodies_) {
+                auto shape = body_ptr->shape();
+                shape.setZero();
+                if (copy_n > 0) {
+                    std::memcpy(shape.data(), beta_ptr, copy_n * sizeof(float));
+                }
+            }
+            return;
+        }
+
+        const size_t row_n = static_cast<size_t>(info.shape[0]);
+        const size_t col_n = static_cast<size_t>(info.shape[1]);
+        if (row_n != bodies_.size()) {
+            throw std::invalid_argument(
+                "2D betas first dimension must equal batch_capacity");
+        }
+        const size_t copy_n = std::min(col_n, n_shape_blends_);
+        for (size_t i = 0; i < bodies_.size(); ++i) {
+            auto shape = bodies_[i]->shape();
+            shape.setZero();
+            if (copy_n > 0) {
+                std::memcpy(shape.data(), beta_ptr + i * col_n,
+                            copy_n * sizeof(float));
+            }
+        }
+    }
+
+    void update(
+        py::array_t<float, py::array::c_style | py::array::forcecast> trans,
+        py::array_t<float, py::array::c_style | py::array::forcecast> pose,
+        bool force_cpu = false, bool enable_pose_blendshapes = true) {
+        (void)run_batch(trans, pose, force_cpu, enable_pose_blendshapes,
+                        OutputMode::kNone);
+    }
+
+    py::array_t<float> forward_last(
+        py::array_t<float, py::array::c_style | py::array::forcecast> trans,
+        py::array_t<float, py::array::c_style | py::array::forcecast> pose,
+        bool force_cpu = false, bool enable_pose_blendshapes = true) {
+        return run_batch(trans, pose, force_cpu, enable_pose_blendshapes,
+                         OutputMode::kLast)
+            .template cast<py::array_t<float>>();
+    }
+
+    py::array_t<float> forward(
+        py::array_t<float, py::array::c_style | py::array::forcecast> trans,
+        py::array_t<float, py::array::c_style | py::array::forcecast> pose,
+        bool force_cpu = false, bool enable_pose_blendshapes = true) {
+        return run_batch(trans, pose, force_cpu, enable_pose_blendshapes,
+                         OutputMode::kFull)
+            .template cast<py::array_t<float>>();
+    }
+
+   private:
+    enum class OutputMode { kNone, kLast, kFull };
+
+    bool can_use_cuda_parallel(size_t batch_n, bool force_cpu) const {
+#ifdef SMPLX_CUDA_ENABLED
+        if (force_cpu || !CUDA_AVAILABLE || batch_n <= 1) {
+            return false;
+        }
+        if (cuda_streams_.size() < batch_n) {
+            return false;
+        }
+        return std::all_of(cuda_streams_.begin(),
+                           cuda_streams_.begin() +
+                               static_cast<std::ptrdiff_t>(batch_n),
+                           [](void* stream_handle) {
+                               return stream_handle != nullptr;
+                           });
+#else
+        (void)batch_n;
+        (void)force_cpu;
+        return false;
+#endif
+    }
+
+    void synchronize_cuda_streams(size_t batch_n) const {
+#ifdef SMPLX_CUDA_ENABLED
+        const size_t n = std::min(batch_n, cuda_streams_.size());
+        for (size_t i = 0; i < n; ++i) {
+            if (cuda_streams_[i] != nullptr) {
+                cudaStreamSynchronize(
+                    reinterpret_cast<cudaStream_t>(cuda_streams_[i]));
+            }
+        }
+#else
+        (void)batch_n;
+#endif
+    }
+
+    py::object run_batch(
+        py::array_t<float, py::array::c_style | py::array::forcecast> trans,
+        py::array_t<float, py::array::c_style | py::array::forcecast> pose,
+        bool force_cpu, bool enable_pose_blendshapes, OutputMode output_mode) {
+        const auto trans_info = trans.request();
+        const auto pose_info = pose.request();
+        if (trans_info.ndim != 2 || trans_info.shape[1] != 3) {
+            throw std::invalid_argument("trans must have shape (batch, 3)");
+        }
+        if (pose_info.ndim != 2 ||
+            pose_info.shape[1] != static_cast<py::ssize_t>(n_pose_params_)) {
+            throw std::invalid_argument(
+                "pose must have shape (batch, n_pose_params)");
+        }
+        if (trans_info.shape[0] != pose_info.shape[0]) {
+            throw std::invalid_argument(
+                "trans and pose must have the same batch dimension");
+        }
+
+        const size_t batch_n = static_cast<size_t>(trans_info.shape[0]);
+        if (batch_n == 0) {
+            throw std::invalid_argument("batch must be non-empty");
+        }
+        if (batch_n > bodies_.size()) {
+            throw std::invalid_argument(
+                "batch exceeds batch_capacity of this fused runner");
+        }
+
+        const auto* trans_ptr = static_cast<const float*>(trans_info.ptr);
+        const auto* pose_ptr = static_cast<const float*>(pose_info.ptr);
+
+        py::array_t<float> output;
+        float* out_ptr = nullptr;
+        if (output_mode == OutputMode::kFull) {
+            output = py::array_t<float>(
+                {static_cast<py::ssize_t>(batch_n),
+                 static_cast<py::ssize_t>(n_verts_), static_cast<py::ssize_t>(3)});
+            out_ptr = output.mutable_data();
+        } else if (output_mode == OutputMode::kLast) {
+            output = py::array_t<float>(
+                {static_cast<py::ssize_t>(n_verts_), static_cast<py::ssize_t>(3)});
+            out_ptr = output.mutable_data();
+        }
+
+        const bool use_cuda_parallel = can_use_cuda_parallel(batch_n, force_cpu);
+
+        {
+            py::gil_scoped_release release;
+            if (use_cuda_parallel) {
+                std::vector<std::thread> workers;
+                workers.reserve(batch_n);
+                for (size_t i = 0; i < batch_n; ++i) {
+                    workers.emplace_back([&, i]() {
+                        auto& body = *bodies_[i];
+                        std::memcpy(body.trans().data(), trans_ptr + i * 3,
+                                    3 * sizeof(float));
+                        std::memcpy(
+                            body.pose().data(), pose_ptr + i * n_pose_params_,
+                            n_pose_params_ * sizeof(float));
+                        body.update_cuda_stream(
+                            force_cpu, enable_pose_blendshapes,
+                            cuda_streams_[i]);
+                    });
+                }
+                for (auto& worker : workers) {
+                    worker.join();
+                }
+                synchronize_cuda_streams(batch_n);
+            } else {
+                for (size_t i = 0; i < batch_n; ++i) {
+                    auto& body = *bodies_[i];
+                    std::memcpy(body.trans().data(), trans_ptr + i * 3,
+                                3 * sizeof(float));
+                    std::memcpy(
+                        body.pose().data(), pose_ptr + i * n_pose_params_,
+                        n_pose_params_ * sizeof(float));
+                    body.update(force_cpu, enable_pose_blendshapes);
+                }
+            }
+
+            if (output_mode == OutputMode::kFull) {
+                for (size_t i = 0; i < batch_n; ++i) {
+                    const auto& verts = bodies_[i]->verts();
+                    std::memcpy(out_ptr + i * n_verts_ * 3, verts.data(),
+                                n_verts_ * 3 * sizeof(float));
+                }
+            } else if (output_mode == OutputMode::kLast) {
+                const auto& verts = bodies_[batch_n - 1]->verts();
+                std::memcpy(out_ptr, verts.data(),
+                            n_verts_ * 3 * sizeof(float));
+            }
+        }
+
+        if (output_mode == OutputMode::kNone) {
+            return py::none();
+        }
+        return std::move(output);
+    }
+
+    py::object model_owner_;
+    const ModelClass* model_;
+    size_t n_pose_params_;
+    size_t n_shape_blends_;
+    size_t n_verts_;
+    std::vector<std::unique_ptr<BodyClass>> bodies_;
+    std::vector<void*> cuda_streams_;
+};
+
+template <class ModelConfig>
+void declare_fused_batch_forward(py::module& m,
+                                 const std::string& py_batch_name) {
+    using FusedBatchForwardClass = FusedBatchForward<ModelConfig>;
+    using ModelClass = Model<ModelConfig>;
+
+    py::class_<FusedBatchForwardClass>(m, py_batch_name.c_str())
+        .def(py::init([](py::object model, size_t batch_capacity) {
+                 model.cast<ModelClass&>();
+                 return FusedBatchForwardClass(std::move(model),
+                                               batch_capacity);
+             }),
+             py::arg("model"), py::arg("batch_capacity"),
+             "Create a fused batch-forward runner bound to a model instance.")
+        .def_property_readonly(
+            "batch_capacity", &FusedBatchForwardClass::batch_capacity,
+            "Maximum batch size accepted by this runner")
+        .def("set_betas", &FusedBatchForwardClass::set_betas,
+             py::arg("betas"),
+             "Set shape parameters. Accepts (n_shape_blends,) or "
+             "(batch_capacity, n_shape_blends).")
+        .def("update", &FusedBatchForwardClass::update, py::arg("trans"),
+             py::arg("pose"), py::arg("force_cpu") = false,
+             py::arg("enable_pose_blendshapes") = true,
+             "Run fused batched updates without returning vertices.")
+        .def("forward_last", &FusedBatchForwardClass::forward_last,
+             py::arg("trans"), py::arg("pose"), py::arg("force_cpu") = false,
+             py::arg("enable_pose_blendshapes") = true,
+             "Run fused batched forward and return vertices for the last row "
+             "(n_verts, 3).")
+        .def("forward", &FusedBatchForwardClass::forward, py::arg("trans"),
+             py::arg("pose"), py::arg("force_cpu") = false,
+             py::arg("enable_pose_blendshapes") = true,
+             "Run fused batched forward and return vertices for all rows "
+             "(batch, n_verts, 3).");
+}
